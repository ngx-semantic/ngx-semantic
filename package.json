{
  "name": "ngx-semantic",
  "version": "0.0.3",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "test": "ng test  --watch=false --code-coverage",
    "test:ci": "ng test  --browsers=ChromeHeadless --watch=false --code-coverage",
